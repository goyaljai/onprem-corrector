# onprem-corrector — copy to .env and adjust. NO secrets belong in this file.
# The service is env-driven; these are the only knobs.

VLLM_BASE_URL=http://localhost:8000/v1     # your local vLLM endpoint (OpenAI-compatible). Never api.openai.com.
MODEL_NAME=nemotron-nano-9b-v2             # the --served-model-name your vLLM advertises
POLICY_DIR=./policy_store                  # where the Chroma index + policy metadata persist
API_PORT=5244                              # the corrector API port

# --- Audit trail (tamper-evident, hash-chained) ---------------------------------------
AUDIT_DIR=./audit_store                    # where the append-only hash-chained log lives
AUDIT_ENABLED=true                         # set false to disable persistence entirely
AUDIT_STORE_MODE=redacted                  # redacted (PII masked) | hashed (only sha of text) | full
AUDIT_RETENTION_DAYS=0                     # 0 = keep forever; N = prune whole segments older than N days
AUDIT_FAIL_CLOSED=false                    # true = a failed audit write fails the request (integrity>availability)
# AUDIT_API_KEY=change-me                  # REQUIRED to enable the /v1/audit* read endpoints (else 403)
# AUDIT_HMAC_KEY=change-me                 # optional: adds an HMAC signature per record (authenticity)
# AUDIT_DB=sqlite:////data/audit.db        # optional best-effort mirror sink; JSONL stays authoritative

# --- Security: API auth + rate limit (issue #2) ---------------------------------------
# API_KEYS=caller-key-1,caller-key-2       # caller keys — may POST /v1/corrector/analyze
# ADMIN_API_KEY=admin-key                  # admin keys — may upload policy + read /v1/audit* (admin ⊇ caller)
AUTH_REQUIRED=false                        # true = refuse ALL requests unless a key is configured+sent
RATE_LIMIT_PER_MIN=0                       # 0 = off; N = max requests/min per identity (best-effort, per-replica)
# Header clients send:  X-API-Key: <key>   ·   If no keys are set the API is OPEN (loud startup warning).

DOCS_ENABLED=true                          # serve interactive Swagger UI at /docs + ReDoc at /redoc

# In docker-compose, the corrector reaches vLLM by service name (http://vllm:8000/v1) and the
# model is pulled from Hugging Face (or mounted via MODEL_PATH) — see deploy/README.md.
