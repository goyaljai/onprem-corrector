# onprem-corrector — copy to .env and adjust. NO secrets belong in this file.
# The service is env-driven; these are the only knobs.

VLLM_BASE_URL=http://localhost:8000/v1     # your local vLLM endpoint (OpenAI-compatible). Never api.openai.com.
MODEL_NAME=nemotron-nano-9b-v2             # the --served-model-name your vLLM advertises
POLICY_DIR=./policy_store                  # where the Chroma index + policy metadata persist
API_PORT=5244                              # the corrector API port

# In docker-compose, the corrector reaches vLLM by service name (http://vllm:8000/v1) and the
# model weights are provided via MODEL_PATH (mounted) — see deploy/README.md.
